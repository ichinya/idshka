APP_NAME=IDShka
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

ISSUER_IDENTIFIER="${APP_URL}"
ISSUER_ALLOWED_ALGS=RS256
ISSUER_USER_API_TOKEN_TTL_SECONDS=900
ISSUER_ID_TOKEN_TTL_SECONDS=300
ISSUER_WEB_ACCESS_TOKEN_TTL_SECONDS=600
ISSUER_AUTHORIZATION_CODE_TTL_SECONDS=300
ISSUER_RSA_BITS=2048
ISSUER_JWKS_CACHE_SECONDS=120
ISSUER_REDIS_DENYLIST_ENABLED=true
ISSUER_REDIS_DENYLIST_PREFIX=issuer:denylist:jti:

SECURITY_RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=10
SECURITY_RATE_LIMIT_AUTH_SOCIAL_PER_MINUTE=30
SECURITY_RATE_LIMIT_SITE_REGISTRY_PER_MINUTE=30
SECURITY_RATE_LIMIT_SITE_VERIFICATION_PER_MINUTE=20
SECURITY_RATE_LIMIT_OAUTH_AUTHORIZE_PER_MINUTE=60
SECURITY_RATE_LIMIT_OAUTH_TOKEN_PER_MINUTE=60
SECURITY_RATE_LIMIT_OAUTH_USERINFO_PER_MINUTE=120
SECURITY_RATE_LIMIT_JWKS_PUBLIC_PER_MINUTE=120
SECURITY_RATE_LIMIT_TOKEN_ISSUE_PER_MINUTE=20
SECURITY_RATE_LIMIT_TOKEN_REVOKE_PER_MINUTE=40
SECURITY_RATE_LIMIT_PORTAL_SITE_WRITE_PER_MINUTE=30
SECURITY_RATE_LIMIT_PORTAL_VERIFICATION_PER_MINUTE=20
SECURITY_RATE_LIMIT_PORTAL_CREDENTIAL_ISSUE_PER_MINUTE=20
SECURITY_RATE_LIMIT_PORTAL_CREDENTIAL_REVOKE_PER_MINUTE=40
SECURITY_RATE_LIMIT_PORTAL_CLIENT_WRITE_PER_MINUTE=20
SECURITY_RATE_LIMIT_PORTAL_REDIRECT_URI_WRITE_PER_MINUTE=30

GATEWAY_LOG_LEVEL=warn

# Local OAuth demos can register and verify localhost/127.0.0.1 sites.
# Keep disabled outside local development.
SITE_REGISTRY_ALLOW_LOOPBACK_DOMAINS=true

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=idshka
DB_USERNAME=idshka
DB_PASSWORD=idshka-local-dev

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
# Leave as null to reuse DB_PASSWORD for local Docker Redis auth.
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

VKONTAKTE_CLIENT_ID=
VKONTAKTE_CLIENT_SECRET=
VKONTAKTE_REDIRECT_URI="${APP_URL}/auth/vk/callback"

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI="${APP_URL}/auth/yandex/callback"

VITE_APP_NAME="${APP_NAME}"
